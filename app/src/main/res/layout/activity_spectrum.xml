<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="4dp">

    <!-- Header -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Spectrum Analyzer (CM108)"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙"
            android:minWidth="40dp"/>
    </LinearLayout>

    <!-- Spectrum display -->
    <com.ar5000.audio.SpectrumView
        android:id="@+id/spectrumView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#ff000000"/>

    <!-- Controls -->
    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="1"
        android:paddingTop="4dp">

        <TableRow>
            <TextView android:text="Center (MHz):" android:padding="2dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etCenter" android:inputType="numberDecimal"
                android:hint="145.000" android:padding="2dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </TableRow>
        <TableRow>
            <TextView android:text="Span (kHz):" android:padding="2dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <Spinner android:id="@+id/spSpan" android:padding="2dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </TableRow>
        <TableRow>
            <TextView android:text="Mode:" android:padding="2dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <Spinner android:id="@+id/spMode" android:padding="2dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </TableRow>
        <TableRow>
            <TextView android:text="Gain:" android:padding="2dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <SeekBar android:id="@+id/sbGain" android:max="100" android:progress="50" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </TableRow>
        <TableRow>
            <TextView android:id="@+id/tvGainVal" android:text="50" android:padding="2dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnApply" android:text="Apply" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </TableRow>
    </TableLayout>

    <!-- Status bar -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Waiting for audio..."
        android:textStyle="italic"
        android:paddingTop="4dp"
        android:gravity="center"/>

</LinearLayout>