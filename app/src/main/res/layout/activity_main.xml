<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- 1. TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="28dp"
        android:background="#E0E0E0"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView android:id="@+id/statusBar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="DISCONNECTED"
            android:textColor="#8B0000"
            android:textStyle="bold"
            android:textSize="11sp"
            android:gravity="center_vertical"
            android:fontFamily="monospace"/>

        <Spinner android:id="@+id/spinnerAnt"
            android:layout_width="80dp"
            android:layout_height="24dp"
            android:background="#FFFFFF"
            android:padding="2dp"
            android:textSize="14sp"
            android:layout_marginEnd="4dp"/>

        <Button android:id="@+id/btnLua"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginVertical="2dp"
            android:layout_marginEnd="4dp"
            android:text="LUA"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/rounded_button"
            android:backgroundTint="#9C27B0"
            android:paddingHorizontal="6dp"
            android:includeFontPadding="false"/>

        <Button android:id="@+id/btnTerminal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Term"
            android:layout_margin="4dp"/>

        <Button android:id="@+id/btnConnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Con"
            android:layout_marginTop="4dp"/>

        <ImageButton android:id="@+id/btnSettings"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings"
            android:scaleType="centerInside"/>
    </LinearLayout>

    <!-- 2. LCD DISPLAY + KNOBS -->
    <LinearLayout android:id="@+id/lcdArea"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:orientation="vertical"
        android:background="#001a00"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="2dp">

        <!-- Status Line (Busy, Key) -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:id="@+id/indBusy" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BUSY" android:textColor="#003300" android:textSize="11sp" android:fontFamily="monospace"/>
            <TextView android:id="@+id/indKey" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KEY" android:textColor="#003300" android:textSize="11sp" android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- Frequency -->
        <TextView android:id="@+id/lcdFreq"
            android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:text="145.000.000" android:textColor="#00ff00" android:textSize="42sp"
            android:fontFamily="monospace" android:gravity="center" android:background="#000000"
            android:layout_marginVertical="2dp"/>

        <!-- Info Line: Mode | Antenna | BW | Step | Signal | REC -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="32dp" android:orientation="horizontal" android:gravity="center_vertical">
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/lcdMode" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FM" android:textColor="#00ff00" android:textSize="14sp" android:fontFamily="monospace"/>
                <TextView android:id="@+id/indAnt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ANT1" android:textColor="#00ff00" android:textSize="14sp" android:layout_marginStart="8dp" android:fontFamily="monospace"/>
                <TextView android:id="@+id/lcdBw" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15K" android:textColor="#00ff00" android:textSize="14sp" android:layout_marginStart="8dp" android:fontFamily="monospace"/>
                <TextView android:id="@+id/lcdStep" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STEP 5K" android:textColor="#00ff00" android:textSize="14sp" android:layout_marginStart="8dp" android:fontFamily="monospace"/>
                <TextView android:id="@+id/lcdSignal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S9" android:textColor="#00ff00" android:textSize="14sp" android:layout_marginStart="8dp" android:fontFamily="monospace"/>
            </LinearLayout>

            <Button android:id="@+id/btnRec"
                android:layout_width="16dp" android:layout_height="16dp"
                android:text="" android:textSize="0sp"
                android:background="@drawable/rounded_button_circle"
                android:layout_marginStart="8dp"
                android:padding="0dp"/>
        </LinearLayout>

        <!-- 4 HARDWARE KNOBS (FIXED) -->





    </LinearLayout>

    <!-- 3. SPECTRUM -->
    <com.ar5000.audio.SpectrumView android:id="@+id/spectrum"
        android:layout_width="0dp" android:layout_height="80dp"
        android:background="#000000"
        app:layout_constraintTop_toBottomOf="@id/lcdArea"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="2dp"/>

    <!-- 4. SQUELCH (Legacy slider kept for compatibility) -->
    <LinearLayout android:id="@+id/squelchPanel"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/spectrum"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:padding="2dp" android:background="#FFFFFF" android:elevation="2dp">
        <TextView android:text="SQL" android:textColor="#111111" android:textSize="14sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <SeekBar android:id="@+id/squelchSlider" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="255" android:progress="0" android:progressTint="#2196F3" android:thumbTint="#2196F3"/>
        <TextView android:id="@+id/sqlValue" android:text="0" android:textColor="#111111" android:textSize="14sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- 5. RF GAIN + IF SHIFT -->
    <LinearLayout android:id="@+id/sliderPanel"
        android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/squelchPanel"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:background="#FFFFFF" android:padding="2dp" android:elevation="2dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
            <TextView android:text="RF" android:textSize="14sp" android:textColor="#111111" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <SeekBar android:id="@+id/sliderRfGain" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="255" android:progress="128" android:progressTint="#2196F3" android:thumbTint="#2196F3"/>
            <TextView android:id="@+id/txtRfGain" android:text="128" android:textSize="14sp" android:textColor="#111111" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:text="IF" android:textSize="14sp" android:textColor="#111111" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <SeekBar android:id="@+id/sliderIfShift" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="6000" android:progress="3000" android:progressTint="#E1BEE7" android:thumbTint="#E1BEE7"/>
            <TextView android:id="@+id/txtIfShift" android:text="0" android:textSize="14sp" android:textColor="#111111" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 6. VFO LIST (Flexible height) -->
    <ScrollView android:id="@+id/vfoScroll"
        android:layout_width="0dp" android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/sliderPanel"
        app:layout_constraintBottom_toTopOf="@id/modePanel"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:background="#FFFFFF" android:padding="2dp" android:elevation="2dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <!-- VFO A -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="2dp" android:layout_marginBottom="2dp" android:background="#F5F5F5" android:gravity="center_vertical">
                <TextView android:text="VFO A" android:textSize="14sp" android:textStyle="bold" android:textColor="#111111" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="4dp" android:gravity="center_vertical"/>
                <EditText android:id="@+id/freqA" android:layout_width="100dp" android:gravity="end|center_vertical" android:layout_height="28dp" android:hint="145.000" android:textSize="14sp" android:inputType="numberDecimal" android:background="#EEEEEE" android:padding="2dp" android:textColor="#000000" android:layout_marginEnd="2dp"/>
                <Spinner android:id="@+id/modeA" android:layout_width="55dp" android:layout_height="28dp" android:background="#E0E0E0" android:padding="1dp" android:layout_marginEnd="2dp"/>
                <Spinner android:id="@+id/bwA" android:layout_width="55dp" android:layout_height="28dp" android:background="#BBDEFB" android:padding="1dp" android:layout_marginEnd="2dp"/>
                <Button android:id="@+id/btnSetA" android:layout_width="70dp" android:layout_height="28dp" android:text="SET" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0"/>
            </LinearLayout>
            <!-- VFO B -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="2dp" android:layout_marginBottom="2dp" android:background="#F5F5F5" android:gravity="center_vertical">
                <TextView android:text="VFO B" android:textSize="14sp" android:textStyle="bold" android:textColor="#111111" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="4dp" android:gravity="center_vertical"/>
                <EditText android:id="@+id/freqB" android:layout_width="100dp" android:gravity="end|center_vertical" android:layout_height="28dp" android:hint="145.000" android:textSize="14sp" android:inputType="numberDecimal" android:background="#EEEEEE" android:padding="2dp" android:textColor="#000000" android:layout_marginEnd="2dp"/>
                <Spinner android:id="@+id/modeB" android:layout_width="55dp" android:layout_height="28dp" android:background="#E0E0E0" android:padding="1dp" android:layout_marginEnd="2dp"/>
                <Spinner android:id="@+id/bwB" android:layout_width="55dp" android:layout_height="28dp" android:background="#BBDEFB" android:padding="1dp" android:layout_marginEnd="2dp"/>
                <Button android:id="@+id/btnSetB" android:layout_width="70dp" android:layout_height="28dp" android:text="SET" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0"/>
            </LinearLayout>
            <!-- VFO C -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="2dp" android:layout_marginBottom="2dp" android:background="#F5F5F5" android:gravity="center_vertical">
                <TextView android:text="VFO C" android:textSize="14sp" android:textStyle="bold" android:textColor="#111111" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="4dp" android:gravity="center_vertical"/>
                <EditText android:id="@+id/freqC" android:layout_width="100dp" android:gravity="end|center_vertical" android:layout_height="28dp" android:hint="145.000" android:textSize="14sp" android:inputType="numberDecimal" android:background="#EEEEEE" android:padding="2dp" android:textColor="#000000" android:layout_marginEnd="2dp"/>
                <Spinner android:id="@+id/modeC" android:layout_width="55dp" android:layout_height="28dp" android:background="#E0E0E0" android:padding="1dp" android:layout_marginEnd="2dp"/>
                <Spinner android:id="@+id/bwC" android:layout_width="55dp" android:layout_height="28dp" android:background="#BBDEFB" android:padding="1dp" android:layout_marginEnd="2dp"/>
                <Button android:id="@+id/btnSetC" android:layout_width="70dp" android:layout_height="28dp" android:text="SET" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0"/>
            </LinearLayout>
            <!-- VFO D -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="2dp" android:layout_marginBottom="2dp" android:background="#F5F5F5" android:gravity="center_vertical">
                <TextView android:text="VFO D" android:textSize="14sp" android:textStyle="bold" android:textColor="#111111" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="4dp" android:gravity="center_vertical"/>
                <EditText android:id="@+id/freqD" android:layout_width="100dp" android:gravity="end|center_vertical" android:layout_height="28dp" android:hint="145.000" android:textSize="14sp" android:inputType="numberDecimal" android:background="#EEEEEE" android:padding="2dp" android:textColor="#000000" android:layout_marginEnd="2dp"/>
                <Spinner android:id="@+id/modeD" android:layout_width="55dp" android:layout_height="28dp" android:background="#E0E0E0" android:padding="1dp" android:layout_marginEnd="2dp"/>
                <Spinner android:id="@+id/bwD" android:layout_width="55dp" android:layout_height="28dp" android:background="#BBDEFB" android:padding="1dp" android:layout_marginEnd="2dp"/>
                <Button android:id="@+id/btnSetD" android:layout_width="70dp" android:layout_height="28dp" android:text="SET" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0"/>
            </LinearLayout>
            <!-- VFO E -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="2dp" android:background="#F5F5F5" android:gravity="center_vertical">
                <TextView android:text="VFO E" android:textSize="14sp" android:textStyle="bold" android:textColor="#111111" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="4dp" android:gravity="center_vertical"/>
                <EditText android:id="@+id/freqE" android:layout_width="100dp" android:gravity="end|center_vertical" android:layout_height="28dp" android:hint="145.000" android:textSize="14sp" android:inputType="numberDecimal" android:background="#EEEEEE" android:padding="2dp" android:textColor="#000000" android:layout_marginEnd="2dp"/>
                <Spinner android:id="@+id/modeE" android:layout_width="55dp" android:layout_height="28dp" android:background="#E0E0E0" android:padding="1dp" android:layout_marginEnd="2dp"/>
                <Spinner android:id="@+id/bwE" android:layout_width="55dp" android:layout_height="28dp" android:background="#BBDEFB" android:padding="1dp" android:layout_marginEnd="2dp"/>
                <Button android:id="@+id/btnSetE" android:layout_width="70dp" android:layout_height="28dp" android:text="SET" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 7. MODE PANEL -->
    <LinearLayout android:id="@+id/modePanel"
        android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/vfoScroll"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:background="#FFFFFF" android:padding="2dp" android:elevation="2dp">
        <Button android:id="@+id/btnModeMemory" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="MEMORY" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0" android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnModeScan" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="SCAN" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0" android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnModeSearch" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="SEARCH" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0"/>
    </LinearLayout>

    <!-- 8. MEMORY PANEL -->
    <LinearLayout android:id="@+id/panelMemory" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/modePanel"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:background="#FFFFFF" android:padding="4dp" android:elevation="2dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
            <TextView android:text="Bank:" android:textSize="11sp" android:textColor="#111111" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <Spinner android:id="@+id/spinnerMemBank" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:background="#E0E0E0" android:layout_marginHorizontal="4dp"/>
            <TextView android:text="Ch:" android:textSize="11sp" android:textColor="#111111" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <Spinner android:id="@+id/spinnerMemCh" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:background="#E0E0E0" android:layout_marginStart="4dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnMemRead" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="READ" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0" android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/btnMemWrite" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="WRITE" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0" android:layout_marginEnd="4dp"/>
            <Button android:id="@+id/btnMemDelete" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="DEL" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0" android:layout_marginEnd="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 9. SCAN PANEL -->
    <LinearLayout android:id="@+id/panelScan" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/panelMemory"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:background="#FFFFFF" android:padding="4dp" android:elevation="2dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
            <TextView android:text="Bank:" android:textSize="11sp" android:textColor="#111111" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <Spinner android:id="@+id/spinnerScanBank" android:layout_width="0dp" android:layout_height="28dp" android:layout_weight="1" android:background="#E0E0E0" android:layout_marginHorizontal="4dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnScanStart" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="START SCAN" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0" android:layout_marginEnd="2dp"/>
            <Button android:id="@+id/btnScanPass" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="PASS SCAN" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0" android:layout_marginEnd="2dp"/>
            <Button android:id="@+id/btnScanLink" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="LINK SCAN" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 10. SEARCH PANEL -->
    <LinearLayout android:id="@+id/panelSearch" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/panelScan"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:background="#FFFFFF" android:padding="4dp" android:elevation="2dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnSearchStart" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="START SRCH" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0" android:layout_marginEnd="2dp"/>
            <Button android:id="@+id/btnSearchPass" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="PASS SRCH" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0" android:layout_marginEnd="2dp"/>
            <Button android:id="@+id/btnSearchBank" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="BANK SRCH" android:textSize="11sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#9C27B0"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 11. ADVANCED TOGGLES (2 rows, pinned to bottom) -->
    <LinearLayout android:id="@+id/advPanel"
        android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/panelSearch"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:background="#FFFFFF" android:padding="2dp" android:elevation="2dp">

        <!-- Row 1: STEP, ATT, NB, AGC, HPF, LPF -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="6" android:layout_marginBottom="2dp">
            <Button android:id="@+id/btnStep" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="STEP" android:textSize="10sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#FFF9C4" android:layout_marginEnd="2dp"/>
            <Button android:id="@+id/btnAtt" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="ATT" android:textSize="10sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#FFCDD2" android:layout_marginEnd="2dp"/>
            <Button android:id="@+id/btnNb" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="NB" android:textSize="10sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#C8E6C9" android:layout_marginEnd="2dp"/>
            <Button android:id="@+id/btnAgc" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="AGC" android:textSize="10sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#C8E6C9" android:layout_marginEnd="2dp"/>
            <Button android:id="@+id/btnHpf" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="HPF" android:textSize="10sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#F0F4C3" android:layout_marginEnd="2dp"/>
            <Button android:id="@+id/btnLpf" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="LPF" android:textSize="10sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#F0F4C3"/>
        </LinearLayout>

        <!-- Row 2: CTCSS, DCS, OFFSET, TXT -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="4">
            <Button android:id="@+id/btnCtcss" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="CTCSS" android:textSize="10sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#BCAAA4" android:layout_marginEnd="2dp"/>
            <Button android:id="@+id/btnDcs" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="DCS" android:textSize="10sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#BCAAA4" android:layout_marginEnd="2dp"/>
            <Button android:id="@+id/btnOffset" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="OFFSET" android:textSize="10sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#CFD8DC" android:layout_marginEnd="2dp"/>
            <Button android:id="@+id/btnTxt" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:text="TXT" android:textSize="10sp" android:textColor="#FFFFFF" android:background="@drawable/rounded_button" android:backgroundTint="#FFCCBC"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>